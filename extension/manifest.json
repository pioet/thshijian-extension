  "icons": {
    "48": "shijian-icon.png",
    "128": "shijian-icon.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.thshijian.tsinghua.edu.cn/f/xs/xmsq/index/*"], 
      "css": ["style.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
